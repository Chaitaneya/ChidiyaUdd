# Supabase Configuration
# Get these credentials from your Supabase project dashboard:
# https://supabase.com/dashboard/project/{PROJECT_ID}/settings/api

# Your Supabase project URL (e.g., https://your-project.supabase.co)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public key (starts with eyJ...)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini API Key (for generating game entities)
GEMINI_API_KEY=your-gemini-api-key-here
